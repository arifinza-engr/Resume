# Copy this file to .env and fill in your values.
# GitHub personal access token (classic). GITHUB_TOKEN is preferred;
# REACT_APP_GITHUB_TOKEN is still accepted for backward compatibility.
GITHUB_TOKEN="YOUR GITHUB TOKEN HERE"
GITHUB_USERNAME="YOUR GITHUB USERNAME HERE"
# Set to "true" to fetch profile data from GitHub at build time.
USE_GITHUB_DATA="true"
# Optional: set your Medium username to fetch blog posts.
MEDIUM_USERNAME="YOUR MEDIUM USERNAME HERE"
