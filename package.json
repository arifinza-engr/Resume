{
  "homepage": "https://developerfolio.js.org/",
  "name": "developerfolio",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@emotion/react": "^11.14.0",
    "colorthief": "^2.7.0",
    "gh-pages": "^2.1.1",
    "lottie-react": "^2.4.1",
    "react": "^19.2.7",
    "react-awesome-reveal": "^4.3.1",
    "react-dom": "^19.2.7",
    "react-easy-emoji": "^1.8.1",
    "react-headroom": "^3.2.1",
    "react-twitter-embed": "3.0.3",
    "sass": "^1.32.8"
  },
  "scripts": {
    "dev": "vite",
    "start": "node fetch.mjs && vite",
    "build": "node fetch.mjs && vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -b master -d build",
    "format": "prettier --write \"./src/**/*.{js,jsx,ts,tsx,css,scss,json}\"",
    "check-format": "prettier -c \"./src/**/*.{js,jsx,ts,tsx,css,scss,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-headroom": "^3.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "dotenv": "^8.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.4.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  }
}
